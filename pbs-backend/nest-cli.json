{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "builder": "tsc",
    "assets": [
      { "include": "**/*.hbs", "watchAssets": true },
      { "include": "**/*.html", "watchAssets": true },
      { "include": "**/*.txt", "watchAssets": true }
    ]
  }
}
