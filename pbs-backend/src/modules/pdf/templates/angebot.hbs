<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: Verdana, Arial, sans-serif; font-size: 12px; color: #222; }
  .page { padding: 18mm 20mm 32mm 20mm; min-height: 257mm; position: relative; }
  .doc-header { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 1.5px solid #333; padding-bottom: 8px; margin-bottom: 14px; }
  .firma-name { font-size: 15px; font-weight: bold; }
  .firma-sub { font-size: 10px; color: #555; margin-top: 2px; }
  .logo { max-height: 48px; max-width: 140px; }
  .empf-block { margin-bottom: 14px; }
  .empf-absender { font-size: 10px; color: #888; margin-bottom: 4px; }
  .doc-meta { display: flex; justify-content: space-between; margin-bottom: 18px; }
  .doc-title { font-size: 17px; font-weight: bold; }
  .doc-subtitle { font-size: 13px; color: #555; margin-top: 3px; }
  .meta-table { font-size: 11px; border-collapse: collapse; }
  .meta-table td { padding: 2px 0; }
  .meta-table td:first-child { color: #555; }
  .meta-table td:last-child { padding-left: 12px; }
  table.pos { width: 100%; border-collapse: collapse; margin-bottom: 10px; }
  table.pos th { background: #f0f0f0; padding: 5px 8px; text-align: left; font-size: 11px; border-bottom: 1.5px solid #ccc; }
  table.pos th.rechts, table.pos td.rechts { text-align: right; }
  table.pos td { padding: 5px 8px; vertical-align: top; border-bottom: 1px solid #e8e8e8; font-size: 11px; }
  table.pos tr:nth-child(even) td { background: #f9f9f9; }
  .totals { margin-left: auto; width: 260px; margin-top: 8px; border-collapse: collapse; }
  .totals td { padding: 3px 6px; font-size: 12px; }
  .totals .brutto td { font-weight: bold; font-size: 13px; border-top: 1.5px solid #333; }
  .zusatz-block { margin-top: 12px; font-size: 11px; color: #444; border-top: 1px solid #eee; padding-top: 8px; }
  .doc-footer { position: absolute; bottom: 10mm; left: 20mm; right: 20mm; border-top: 0.5px solid #ccc; padding-top: 5px; font-size: 9px; color: #666; display: flex; justify-content: space-between; gap: 20px; }
  .doc-footer > div { flex: 1; }
</style>
</head>
<body>
<div class="page">
  {{> header}}

  <div class="empf-block">
    <div class="empf-absender">{{firma.firma}} · {{firma.strasse}} · {{firma.ort}}</div>
    <div style="font-weight:bold">{{angebot.empf}}</div>
    {{#if angebot.str}}<div>{{angebot.str}}</div>{{/if}}
    {{#if angebot.ort}}<div>{{angebot.ort}}</div>{{/if}}
  </div>

  <div class="doc-meta">
    <div>
      <div class="doc-title">Angebot</div>
      {{#if angebot.titel}}<div class="doc-subtitle">{{angebot.titel}}</div>{{/if}}
    </div>
    <table class="meta-table">
      <tr><td>Angebots-Nr.:</td><td><strong>{{angebot.nr}}</strong></td></tr>
      <tr><td>Datum:</td><td>{{angebot.datumFormatiert}}</td></tr>
      <tr><td>Gültig bis:</td><td>{{angebot.gueltigBisFormatiert}}</td></tr>
    </table>
  </div>

  <table class="pos">
    <thead>
      <tr>
        <th style="width:32px">Pos.</th>
        <th style="width:70px">Stunden</th>
        <th>Bezeichnung</th>
        <th class="rechts" style="width:110px">Einzelpreis</th>
        <th class="rechts" style="width:110px">Gesamtpreis</th>
      </tr>
    </thead>
    <tbody>
      {{#each angebot.positionen}}
      <tr>
        <td>{{posNr @index}}</td>
        <td>{{#if stunden}}{{stunden}}{{else}}–{{/if}}</td>
        <td>{{{bezHtml bez}}}</td>
        <td class="rechts">{{#if einzelpreis}}{{fmtEur einzelpreis}}{{else}}Pauschal{{/if}}</td>
        <td class="rechts">{{fmtEur gesamtpreis}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <table class="totals">
    <tr><td>Nettobetrag:</td><td style="text-align:right">{{angebot.nettoFormatiert}}</td></tr>
    <tr><td>MwSt. 19 %:</td><td style="text-align:right">{{angebot.ustFormatiert}}</td></tr>
    <tr class="brutto"><td><strong>Gesamtbetrag:</strong></td><td style="text-align:right"><strong>{{angebot.bruttoFormatiert}}</strong></td></tr>
  </table>

  <div style="margin-top:5mm;font-size:12px;line-height:1.6">
    <p>Dieses Angebot ist <strong>30 Tage</strong> gültig. Bei Fragen stehen wir Ihnen gerne zur Verfügung.</p>
    <p style="margin-top:4px">Wir würden uns sehr freuen, wenn unser Angebot Ihre Zustimmung findet.</p>
  </div>

  {{#if angebot.zusatz}}
  <div class="zusatz-block">
    <strong>Zusätzliche Vereinbarungen:</strong><br>
    {{{angebot.zusatzHtml}}}
  </div>
  {{/if}}

  {{> footer}}
</div>
</body>
</html>
