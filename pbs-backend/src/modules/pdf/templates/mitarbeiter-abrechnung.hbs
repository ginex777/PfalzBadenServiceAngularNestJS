<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: Verdana, Arial, sans-serif; font-size: 10px; color: #000; }
  .page { padding: 18mm 20mm 30mm 20mm; min-height: 257mm; position: relative; }
  .doc-header { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 1.5px solid #333; padding-bottom: 8px; margin-bottom: 14px; }
  .firma-name { font-size: 15px; font-weight: bold; }
  .firma-sub { font-size: 10px; color: #555; margin-top: 2px; }
  .logo { max-height: 48px; max-width: 140px; }
  h1 { font-size: 15px; font-weight: 700; margin-bottom: 3px; }
  .sub { font-size: 10px; color: #555; margin-bottom: 14px; }
  table { width: 100%; border-collapse: collapse; margin-bottom: 10px; }
  th { background: #f0f0f0; padding: 5px 8px; text-align: left; border-bottom: 2px solid #000; font-size: 8.5px; text-transform: uppercase; letter-spacing: 0.3px; }
  td { padding: 5px 8px; border-bottom: 1px solid #e8e8e8; font-size: 9.5px; }
  tr:nth-child(even) td { background: #f9f9f9; }
  .rechts { text-align: right; }
  .mitte { text-align: center; }
  tfoot tr td { font-weight: 700; border-top: 2px solid #000; background: #f0f0f0; padding: 6px 8px; }
  .summary { display: flex; gap: 16px; margin-top: 12px; padding: 10px 12px; background: #f8f8f8; border: 1px solid #ddd; border-radius: 4px; flex-wrap: wrap; }
  .si { text-align: center; min-width: 80px; }
  .si .val { font-size: 13px; font-weight: 700; }
  .si .lbl { font-size: 8px; color: #666; margin-top: 2px; }
  .green { color: #16a34a; }
  .red { color: #dc2626; }
  .orange { color: #d97706; }
  .doc-footer { position: absolute; bottom: 10mm; left: 20mm; right: 20mm; border-top: 0.5px solid #ccc; padding-top: 5px; font-size: 9px; color: #666; display: flex; justify-content: space-between; gap: 20px; }
  .doc-footer > div { flex: 1; }
</style>
</head>
<body>
<div class="page">
  {{> header}}

  <h1>Stundenabrechnung – {{mitarbeiter.name}}</h1>
  <div class="sub">{{#if mitarbeiter.rolle}}{{mitarbeiter.rolle}} · {{/if}}Stundenlohn: {{stundenlohnFormatiert}} · Erstellt: {{erstelltAm}}</div>

  <table>
    <thead>
      <tr>
        <th>Datum</th>
        <th class="rechts">Std.</th>
        <th>Einsatzort</th>
        <th>Tätigkeit</th>
        <th class="rechts">Grundlohn</th>
        <th class="rechts">Zuschlag</th>
        <th class="rechts">Gesamt</th>
        <th class="mitte">Bezahlt</th>
      </tr>
    </thead>
    <tbody>
      {{#each stunden}}
      <tr>
        <td style="white-space:nowrap">{{datumFormatiert}}</td>
        <td class="rechts">{{stunden}} h</td>
        <td>{{ort}}</td>
        <td>{{beschreibung}}</td>
        <td class="rechts">{{fmtEur lohn}}</td>
        <td class="rechts" style="color:#d97706">{{#if zuschlag}}{{fmtEur zuschlag}} ({{zuschlag_typ}}){{else}}–{{/if}}</td>
        <td class="rechts" style="font-weight:600">{{fmtEur gesamt}}</td>
        <td class="mitte">{{#if bezahlt}}✓{{else}}–{{/if}}</td>
      </tr>
      {{/each}}
    </tbody>
    <tfoot>
      <tr>
        <td>Gesamt</td>
        <td class="rechts">{{gesamtStunden}} h</td>
        <td colspan="2"></td>
        <td class="rechts">{{fmtEur gesamtGrundlohn}}</td>
        <td class="rechts" style="color:#d97706">{{#if gesamtZuschlag}}{{fmtEur gesamtZuschlag}}{{else}}–{{/if}}</td>
        <td class="rechts">{{fmtEur gesamtLohn}}</td>
        <td></td>
      </tr>
    </tfoot>
  </table>

  <div class="summary">
    <div class="si"><div class="val">{{gesamtStunden}} h</div><div class="lbl">Gesamtstunden</div></div>
    <div class="si"><div class="val">{{fmtEur gesamtGrundlohn}}</div><div class="lbl">Grundlohn</div></div>
    <div class="si"><div class="val orange">{{fmtEur gesamtZuschlag}}</div><div class="lbl">Zuschläge</div></div>
    <div class="si"><div class="val">{{fmtEur gesamtLohn}}</div><div class="lbl">Gesamtlohn</div></div>
    <div class="si"><div class="val green">{{fmtEur bezahlt}}</div><div class="lbl">Bezahlt</div></div>
    <div class="si"><div class="val {{offerFarbe}}">{{fmtEur offen}}</div><div class="lbl">Offen</div></div>
  </div>

  {{> footer}}
</div>
</body>
</html>
